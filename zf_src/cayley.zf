::let := \x.\f. f x;

::and := \a.\b. !(a -> !b) ;
::or := \a.\b. !a -> b ;
::iff := \a.\b. ::and (a -> b) (b -> a);
::exists := \fn.!\/x.!(fn x);
::eq := \a.\b. (\/z. ::iff z#a z#b) ;

::subset := \A. \B.  \/x. x#A -> x#B ;
::union := \A. \B. \S. \/a. ::iff a#S (::or a#A a#B);

::unique := \B. ::exists \x. ::and (B x) (\/y. (B y) -> (::eq x y)) ;

::unordered_pair := \x.\y. \S. \/a. ::iff a#S (::or (::eq a x) (::eq a y)) ;
::pair := \x.\y. \S. ::exists \Q. ::and (::unordered_pair x y Q) (::unordered_pair x Q S) ;
::car := \P. \v. ::exists \y. ::pair v y P ;
::cdr := \P. \v. ::exists \x. ::pair x v P ;
::cartesian_product := \A.\B.\S. \/P. ::iff P#S (::exists \x. ::exists \y. ::and (::and x#A y#B) (::pair x y P));

::Apply := \S. \x. \v. ::and 
	(::exists \Q. ::and (::pair x v Q) Q#S)
	(\/y.\/Q.(::and (::pair x y Q) Q#S) -> (::eq y v)) ;
::domain := \f.\A. \/x. ::iff x#A (::exists \y. ::Apply f x y);
::range := \f.\A. \/y. (::exists \x. ::Apply f x y) -> y#A;
::Map := \F. \/f. (\/x.\/y. ::iff (::Apply F x y) (::Apply f x y)) -> (::subset F f) ;


::inverse := \f. \fi. \/x. \/y. ::iff (::Apply f x y) (::Apply fi y x);
::injection := \f. \/x.\/y. (::Apply f x y) -> (::unique \x. ::Apply f x y) ;
::bijection := \f. ::exists (::inverse f);
::surjection := \A.\f. \/y. ::iff y#A (::exists \x. ::Apply f x y);

::compose := \f. \g. \h. \/x. \/z. 
	::iff (::exists \y. ::and (::Apply g x y) (::Apply f y z)) (::Apply h x z) ;

::id := \f.\/x.(::exists \y. ::Apply f x y)->(::Apply f x x) ;

::gmul := \op. \a. \b. \c. ::exists \P. 
	::and 	(::pair a b P) 
		(::Apply op P c) ;

::group_identity := \G. \op. \I.
	::and I#G \/x. x#G -> 
	(::and 	(::gmul op x I x) 
		(::gmul op I x x)) ;

::group_inverse := \G. \op. \x. \xi.
	::exists \I. 
		::and 	(::group_identity G op I) 
		(::and 	(::and x#G xi#G) 
		(::and 	(::gmul op x xi I) 
			(::gmul op xi x I))) ;

::group := \G. \op.
	::and (::exists (::group_identity G op)) 
	(::and (\/x. x#G -> (::exists (::group_inverse G op x)))
	(::and (\/x. x#G -> \/y. y#G -> (::exists \z. ::and z#G (::gmul op x y z)))
		\/x. x#G -> \/y. y#G -> \/z. z#G -> 
		(::exists \v. ::and 
			(::exists \q. ::and (::gmul op x y q) (::gmul op q z v))
			(::exists \q. ::and (::gmul op y z q) (::gmul op x q v))))) ;


::subgroup := \G.\o1.\K.\o2.  
	::and 	(::subset K G) 
	(::and 	(::subset o2 o1)
	(::and 	(::group G o1) 
		(::group K o2))) ;















--law of denied antecedent !p -> p -> q
::loda := \p.\q. {x : !p} ::A3 q p (::A1 !p !q x) ;

--law of double negation  !!p -> p
::ldn := \x. | !!p => (::A3 p !!p) (::loda !p !!!p x) x; 
--converse law of double negation p -> !!p
::cldn := \x. | p => (::A3 !!p p) ({x : !!!p} ::ldn x) x ;

-- ::clavius's law (~q -> q) -> q
::cl := \q. { a : !q -> q } (::A3 q (!q -> q)) 
	({b : !q} ::loda q !(!q -> q) b (a b)) a ;

-- boolean case analysis (a -> b) -> (!a -> b) -> b
::bool_cases := \a. | A -> B => {b : !A -> B} 
	(::cl B) ({q : !B} a ((::A3 A !B) 
		({c : !A } ::cldn (b c)) q)) ;


-- (a -> b) -> (!b -> !a)
-- (!a -> !b) -> (b -> a)

::base_contrapose := \p. 
	| x -> y => ::A3 !x !y ({v : !!x} ::cldn (p (::ldn v)));

::not_contrapose := \p. 
	| !x -> !y => ::A3 x y p ;

::contrapose := \p. 
	| !x -> !y => ::A3 x y p
	| x -> y => ::A3 !x !y ({v : !!x} ::cldn (p (::ldn v)));



-- a -> b -> ::and a b
::and_intro := \f. | a => \g. | b => ({t : ::and a b} t) 
	(::not_contrapose ({ q : !!(a -> !b) } ::ldn q f) g);

-- ::and a b -> a
::and_l := \p.
	| ::and a b => ::not_contrapose (({q : !a} ::cldn (::loda a !b q))) p;

-- ::and a b -> b
::and_r := \p. 
	| ::and a b => ::not_contrapose (({q : !b} ::cldn (::A1 !b a q))) p;

-- ::and a b -> ::and b a
::and_comm := \a. | ::and x y => ::and_intro (::and_r a) (::and_l a) ;




-- a -> ::or a b
::or_intro_l := \a. \b. { p : a } ({t : ::or a b} t) ({ q: !a } ::loda a b q p) ;

-- b -> ::or a b
::or_intro_r := \a. \b. {p : b} ({t : ::or a b} t) (::A1 b !a p) ;

-- ::or case analysis (::or a b) -> (a -> c) -> (b -> c) -> c
::or_cases := \P. | ::or A B => 
		\Q. | [A] -> C => { q : B -> C } 
			::bool_cases Q ({x : !A} q (P x));

-- ::or a b -> ::or b a
::or_comm := \a. | ::or x y =>
	::or_cases a
		(::or_intro_r y x)
		(::or_intro_l y x) ;




-- !\/y. A -> ::exists \y. !A
::not_forall := \p1.| !\/y. A => (::base_contrapose { p2 : \/y. !!(A y)} \/y. ::ldn (p2 y)) p1 ;

-- !(::and a b) -> ::or !a !b
::not_and :=  \a. | !(::and x y) => ::or_comm (::base_contrapose (::ldn a)) ;

-- !(::or a b) -> ::and !a !b
::not_or := \a. | !(::or x y) => ({t : ::and !a !b} t) (::base_contrapose ({v1 : ::or x !!y} {v2 : !x} ::ldn (v1 v2)) a) ;





-- A R -> (::exists \x. A x)
::exists_intro := \A. \/R. {x : A R} 
		({t : ::exists A} t) ((::A3 !(\/x. !(A x)) (A R) 
		({y : !!(\/x. !(A x))} ::loda (A R) !(A R)
			 (::ldn y R) x )) x) ;

-- (::exists A) -> (\/x. (A x) -> (B x)) -> (::exists B);
::exists_mp::1 := \A. \B. {x : ::exists A} {y : \/x. (A x) -> (B x)} 
	({t : ::exists B} t) (::bool_cases
		({v : (A _)} ::exists_intro B _ (y _ v))
		(::not_contrapose {v : !(::exists B)} ::cldn 
			(::loda (\/q. !(A q)) (A _) x 
				\/q. ::base_contrapose ({t : A q} y q t) (::ldn v q))))
;
::exists_mp := \x. | ::exists \x. A => \y. | \/x. A -> B => ::exists_mp::1 A B x y;

::exists_strip := \p. | ::exists \x. A =>
	::bool_cases
		({v : A _} v)
		({v : !(A _)} ::loda (\/z. !(A _)) (A _) p (\/z. v))
;

-- (::exists \a. ::exists \b. F a b) -> (::exists \b. ::exists \a. F a b)
::exists_flip := \A. | !\/a.!!\/b.!F =>
	({t : ::exists \b. ::exists \a. F a b} t) (::bool_cases ({v : ::exists \b. ::exists \a. F a b} v)
	{B : !(::exists \b. ::exists \a. F a b)} 
	::loda (::exists \b. ::exists \a. F a b) (::exists \b. ::exists \a. F a b) B
	(::exists_strip
		(::exists_mp A
		(\/a. {C : ::exists \b. F a b}
			::loda (\/P. !(F a P)) (::exists \b. ::exists \a. F a b) C
			(\/P. ::ldn (::ldn B P) a)))))
;

::_unpack_exists := \p. | ::exists \x. B => \f. \/x. {Q : B x} f x Q ;
::unpack_exists := \p. | ::exists \x. B => \f. ::exists_strip (::exists_mp p (\/x. {p1 : B x} f x p1)) ;




::iff_lr := ::and_l ;
::iff_rl := ::and_r ;
::iff_intro := \p. | a -> b => {q : b -> a} ({t : ::iff a b} t) (::and_intro p q) ;
::iff_trans := \x. | ::iff a b => \y. | ::iff [b] c =>
	::iff_intro
		({v : a} ::iff_lr y (::iff_lr x v))
		({v : c} ::iff_rl x (::iff_rl y v))
;
::iff_comm := \p. | ::iff a b => ::iff_intro (::iff_rl p) (::iff_lr p) ;
::iff_mp := \x. | ::iff a b => \y. 
	| [a] => ::iff_lr x y
	| [b] => ::iff_rl x y ;

::unique_intro := \a. | ::exists \x. A => {b : \/x. \/y. (A x) -> (A y) -> (::eq x y)}
	({t : ::unique A} t) (::exists_mp a (\/z. {v : A z} ::and_intro v (\/q. b z q v))) ;


::ax_pairing : \/x.\/y. ::exists \z. ::and x#z y#z : ::Z4 ;
::ax_ext : \/x. \/y. (::eq x y) -> \/z. ::iff x#z y#z : ::Z1 ;
::ax_union : \/w. ::exists \a. \/y. \/x. (::and x#y y#w) -> x#a : ::Z5 ;
::ax_regularity : \/x. (::exists \a. a#x) -> 
	(::exists \y. ::and y#x !(::exists \z. ::and z#y z#x)) : ::Z2 ;
::ax_powerset : \/x. ::exists \y. \/z.(::subset z x)->z#y : ::Z8;

-- \/y. ::exists \x. \/z. ::iff z#x (::and z#y (B z))
::subset_exists := \B. \/y. ::Z3 y _ (B _);


::eq_refl : \/a. ::eq a a : \/a.\/z. ::iff_intro ({x : z#a} x) ({x : z#a} x);
::eq_symm : \/a. \/b. (::eq a b) -> (::eq b a) : 
	\/a. \/b. { x : ::eq a b } \/z. ::iff_intro (::iff_rl (x z)) (::iff_lr (x z));
::eq_trans : \/a. \/b. \/c. (::eq a b) -> (::eq b c) -> (::eq a c) : 
	\/a. \/b. \/c. {x : ::eq a b} {y : ::eq b c} \/z. ::iff_trans (x z) (y z);
::eq_ext := \p. | ::eq x y => ::ax_ext (x p) (y p) p ;



::not_in_self : \/x. { p1 : x#x }
	::unpack_exists (::ax_pairing x x)
	\_P.\p2.
	::unpack_exists (::subset_exists (\z. ::eq x z) _P)
	\P.\p3.

	::let (::iff_rl (p3 x) (::and_intro (::and_l p2) (::eq_refl x))) 
	\lemma1. -- x#P
	
	::unpack_exists (::ax_regularity P 
	(::exists_intro (\a. a#P) x lemma1))
	\y.\p4. 
	::loda (::exists \z. ::and z#y z#P) !x#x (::and_r p4)
	(::exists_intro (\z. ::and z#y z#P) x
	(::and_intro 
		(::iff_lr (::and_r (::iff_lr (p3 y) (::and_l p4)) x) p1) -- ::eq x#y
		lemma1))
;


::unordered_pair_l : \/x. \/y. \/P. { p1 : ::unordered_pair x y P }
	::iff_rl (p1 x) (::or_intro_l (::eq x x) (::eq x y) (::eq_refl x)) ;
::unordered_pair_r : \/x. \/y. \/P. { p1 : ::unordered_pair x y P }
	::iff_rl (p1 y) (::or_intro_r (::eq y x) (::eq y y) (::eq_refl y)) ;

::eq_unordered_pair : \/P1.\/P2.\/x1.\/x2.\/y1.\/y2.(::eq x1 x2)->(::eq y1 y2)->
(::unordered_pair x1 y1 P1)->(::unordered_pair x2 y2 P2)->(::eq P1 P2)
: \/P1.\/P2.\/x1.\/x2.\/y1.\/y2. {p1 : ::eq x1 x2} {p2 : ::eq y1 y2}
	{p3 : ::unordered_pair x1 y1 P1} { p4 : ::unordered_pair x2 y2 P2}
	
	\/a. ::iff_intro
	({ p5 : a#P1 }
		::or_cases (::iff_lr (p3 a) p5)
		({p6 : ::eq a x1}
			::iff_rl (p4 a) 
			(::or_intro_l (::eq a x2) (::eq a y2) (::eq_trans p6 p1)))
		({p6 : ::eq a y1}
			::iff_rl (p4 a) 
			(::or_intro_r (::eq a x2) (::eq a y2) (::eq_trans p6 p2))))
	({ p5 : a#P2 }
		::or_cases (::iff_lr (p4 a) p5)
		({p6 : ::eq a x2}
			::iff_rl (p3 a) 
			(::or_intro_l (::eq a x1) (::eq a y1) (::eq_trans p6 (::eq_symm p1))))
		({p6 : ::eq a y2}
			::iff_rl (p3 a) 
			(::or_intro_r (::eq a x1) (::eq a y1) (::eq_trans p6 (::eq_symm p2)))))
;



::unordered_pair_exists : \/x. \/y. ::exists (::unordered_pair x y)
: \/x. \/y.
	::unpack_exists (::ax_pairing x y)
	\_P.\p1.
	::unpack_exists (::subset_exists (\z. ::or (::eq z x) (::eq z y)) _P)
	\P.\p2.
	::exists_intro (::unordered_pair x y) P
	(\/z. ::iff_trans (p2 z)
	(::iff_intro
		({p3 : ::and z#_P (::or (::eq z x) (::eq z y))} ::and_r p3)
		{p3 : ::or (::eq z x) (::eq z y)}
			::and_intro (::or_cases p3
			({p4 : ::eq z x} ::iff_rl (::eq_ext p4 _P) (::and_l p1))
			{p4 : ::eq z y} ::iff_rl (::eq_ext p4 _P) (::and_r p1)) 
			p3)) ;

::pair_car : \/x. \/y. \/P. (::pair x y P) -> (::car P x) :
\/x. \/y. \/P. { p1 : ::pair x y P }
	::exists_intro (\y. ::pair x y P) y p1 ;

::pair_cdr : \/x. \/y. \/P. (::pair x y P) -> (::cdr P y) :
\/x. \/y. \/P. { p1 : ::pair x y P }
	::exists_intro (\x. ::pair x y P) x p1 ;

::pair_exists : \/x. \/y. ::exists (::pair x y)
: \/x. \/y.
	::unpack_exists (::unordered_pair_exists x y)
	\Q.\p1.
	::unpack_exists (::unordered_pair_exists x Q)
	\P.\p2.

	::exists_intro (::pair x y) P
	(::exists_intro (\Q. ::and (::unordered_pair x y Q) (::unordered_pair x Q P)) Q
		(::and_intro p1 p2)) ;

::car_eq : \/P. \/x1. \/x2. (::car P x1) -> (::car P x2) -> (::eq x1 x2) : 
\/P. \/x1. \/x2. { p1 : ::car P x1 } { p2 : ::car P x2 }
	::unpack_exists p1
	\y1.\p3. -- ::pair x1 y1 P
	::unpack_exists p2
	\y2.\p4. -- ::pair x2 y2 P
	::unpack_exists p3
	\Q1.\p5. -- ::and (::unordered_pair x1 y1 Q1) (::unordered_pair x1 Q1 P)
	::unpack_exists p4
	\Q2.\p6. --- ::and (::unordered_pair x2 y2 Q2) (::unordered_pair x2 Q2 P)

	::let (::unordered_pair_l (::and_l p5)) \lemma1. -- x1#Q1
	::let (::unordered_pair_l (::and_l p6)) \lemma2. --x2#Q2
	::let (::unordered_pair_l (::and_r p5)) \lemma5. -- x1#P
	::let (::unordered_pair_l (::and_r p6)) \lemma6. --x2#P
	
	::or_cases (::iff_lr (::and_r p6 x1) lemma5)
	({p9 : ::eq x1 x2} p9)
	{p9 : ::eq x1 Q2} 
	::unpack_exists (::ax_regularity P (::exists_intro (\a. a#P) x1 lemma5))
	\y.\p11.
	::loda (::exists \z. ::and z#y z#P) (::eq x1 x2) (::and_r p11)
	(::or_cases (::iff_lr (::and_r p5 y) (::and_l p11))
	({p12 : ::eq y x1}
		(::exists_intro (\z. ::and z#y z#P) x2 
			(::and_intro (::iff_rl (::eq_trans p12 p9 x2) lemma2) lemma6)))
	{p12 : ::eq y Q1}
		(::exists_intro (\z. ::and z#y z#P) x1 
			(::and_intro (::iff_rl (p12 x1) lemma1) lemma5)))
;


::cdr_eq : \/P. \/y1. \/y2. (::cdr P y1) -> (::cdr P y2) -> (::eq y1 y2)
: \/P. \/y1. \/y2. { p1 : ::cdr P y1 } { p2 : ::cdr P y2 }
	::unpack_exists p1
	\x1.\p3. -- ::pair x1 y1 P
	::unpack_exists p2
	\x2.\p4. -- ::pair x2 y2 P
	::unpack_exists p3
	\Q1.\p5. -- ::and (::unordered_pair x1 y1 Q1) (::unordered_pair x1 Q1 P)
	::unpack_exists p4
	\Q2.\p6. --- ::and (::unordered_pair x2 y2 Q2) (::unordered_pair x2 Q2 P)

	::let (::car_eq (::pair_car p3) (::pair_car p4)) 
	\lemma0. --::eq x1 x2

	::let (::unordered_pair_l (::and_l p5)) \lemma1. -- x1#Q1
	::let (::unordered_pair_r (::and_r p5)) \lemma2. -- Q1#P

	::let (::bool_cases
	(({ p7 : ::eq Q1 x1 }
		::let (::iff_lr (p7 x1) lemma1) \lemma3.
		::loda x1#x1 (::eq Q1 Q2) (::not_in_self lemma3) lemma3))
	{p7 : !(::eq Q1 x1)}
		::or_cases (::iff_lr (::and_r p6 Q1) lemma2)
		({p8 : ::eq Q1 x2}
			::loda (::eq Q1 x1) (::eq Q1 Q2) p7
			(::eq_trans p8 (::eq_symm lemma0)))
		{p8 : ::eq Q1 Q2} p8)
	\lemma4. --::eq Q1 Q2

	::let (::iff_lr (lemma4 y1) (::unordered_pair_r (::and_l p5))) 
	\lemma5. -- y1#Q2
	::let (::iff_rl (lemma4 y2) (::unordered_pair_r (::and_l p6))) 
	\lemma6. -- y2#Q1

	::or_cases (::iff_lr (::and_l p6 y1) lemma5)
	({ p7 : ::eq y1 x2} 
		::or_cases (::iff_lr (::and_l p5 y2) lemma6)
		({ p8 : ::eq y2 x1} 
			::eq_trans (::eq_trans p7 (::eq_symm lemma0)) (::eq_symm p8))
		{ p8 : ::eq y2 y1} ::eq_symm p8)
	{ p7 : ::eq y1 y2} p7
;

::eq_pair : \/P1.\/P2.\/x1.\/x2.\/y1.\/y2.(::eq x1 x2)->(::eq y1 y2)->
	(::pair x1 y1 P1)->(::pair x2 y2 P2)->(::eq P1 P2)
: \/P1.\/P2.\/x1.\/x2.\/y1.\/y2. {p1 : ::eq x1 x2} {p2 : ::eq y1 y2}
	{p3 : ::pair x1 y1 P1} { p4 : ::pair x2 y2 P2}
	::unpack_exists p3
	\Q1.\p5.
	::unpack_exists p4
	\Q2.\p6.

	::eq_unordered_pair p1 
		(::eq_unordered_pair p1 p2 (::and_l p5) (::and_l p6))
		(::and_r p5) (::and_r p6) ;


::eq_apply : \/f.\/x1.\/x2.\/y1.\/y2.(::eq x1 x2)->(::Apply f x1 y1)->(::Apply f x2 y2)->(::eq y1 y2)
: \/f.\/x1.\/x2.\/y1.\/y2.{ p0 : ::eq x1 x2}
{p1 : ::Apply f x1 y1} {p2 : ::Apply f x2 y2}
	::unpack_exists (::and_l p1)
	\PP1.\p3. -- ::and (::pair x1 y1 PP1) PP1#f
	::unpack_exists (::pair_exists x2 y1)
	\PP2.\p4.

	::and_r p2
	(::and_intro p4 (::iff_lr (::eq_ext (::eq_pair p0 (::eq_refl y1) (::and_l p3) p4) f)
		(::and_r p3))) ;

::apply_eq : \/f1.\/f2.\/x1.\/x2.\/y1.\/y2.(::eq f1 f2)->(::eq x1 x2)->(::eq y1 y2)->(::Apply f1 x1 y1)->(::Apply f2 x2 y2)
: \/f1.\/f2.\/x1.\/x2.\/y1.\/y2.
	{p0 : ::eq f1 f2} {p1 : ::eq x1 x2} {p2 : ::eq y1 y2}
	{p3 : ::Apply f1 x1 y1}

	::let (::unpack_exists (::and_l p3)
	\Q.\p4.
	::unpack_exists (::pair_exists x2 y2)
	\Q1.\p5.
	::exists_intro (\Q. ::and (::pair x2 y2 Q) Q#f2) Q1
	(::and_intro p5
	(::iff_lr (::eq_ext (::eq_pair p1 p2 (::and_l p4) p5) f2) (::iff_lr (p0 Q) (::and_r p4)))))
	\lemma1. -- ::exists \Q. ::and (::pair x2 y2 Q) Q#f2


::and_intro lemma1
\/y.\/Q. {p4 : ::and (::pair x2 y Q) Q#f2}
	::unpack_exists (::pair_exists x1 y)
	\Q1.\p5.

	::eq_trans (::and_r p3
	(::and_intro p5
	(::iff_rl 
		(p0 Q1)
		(::iff_rl (::eq_ext (::eq_pair p1 (::eq_refl y) p5 (::and_l p4)) f2) 
			(::and_r p4))))) p2

	
	
	
;



::inverse_injective : \/f. \/fi. (::inverse f fi) -> (::injection f)
: \/f. \/fi. { p0 : ::inverse f fi } 
\/x.\/y. {p1 : ::Apply f x y}
::unique_intro (::exists_intro (\x. ::Apply f x y) x p1)
\/x1.\/x2. {p2 : ::Apply f x1 y} {p3 : ::Apply f x2 y}
	::unpack_exists (::and_l (::iff_lr (p0 x1 y) p2))
	\Q.\p4.
	::and_r (::iff_lr (p0 x2 y) p3) x1 p4 ;



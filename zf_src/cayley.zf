		(::gmul_eq (::eq_refl a) (::eq_symm lemma2)
			(::eq_refl abc) p9)) --eq abc1 abc
		(::and_r p10)
		
		
	
		
		
	


;



::cayley_theorem : \/G1.\/op.\/G2.\/c.(::group G1 op)->
(\/f.::iff f#G2 (::and (::bijection_map G1 f) (::exists \a. ::and a#G1 \/x. x#G1 -> \/y. y#G1 ->
	(::iff (::gmul op a x y) (::Apply f x y))))) ->
(\/f.f#G2->\/g.g#G2->\/h.h#G2->(::iff (::gmul c f g h) (::compose f g h))) ->
(::group G2 c)
: \/G1.\/op.\/G2.\/c.
	{ p1 : ::group G1 op }
	{ p2 : \/f. ::iff f#G2 
		(::and (::bijection_map G1 f) 
			(::exists \a. ::and a#G1 \/x. x#G1 -> \/y. y#G1 ->
				(::iff (::gmul op a x y) (::Apply f x y))))
	}
	{ p3 : \/f. f#G2 -> \/g. g#G2 -> \/h. h#G2 -> 
		(::iff (::gmul c f g h) (::compose f g h)) }

	::unpack_exists (::and_l p1)
	\GI.\p4.

	::unpack_exists (::id_bijection_map_exists G1)
	\I.\p5.

	::let (::iff_rl (p2 I)
	(::and_intro
	(::and_r p5)
	(::exists_intro (\a. ::and a#G1 \/x. x#G1 -> \/y. y#G1 -> (::iff (::gmul op a x y) (::Apply I x y))) GI 

	(::and_intro (::and_l p4)
	\/x. { p6 : x#G1 } \/y. {p7 : y#G1}
		::iff_intro
		({ p8 : ::gmul op GI x y }
			::unpack_exists p8
			\P1.\p9.
			::unpack_exists (::and_r (::and_r p4 p6))
			\P2.\p10.
			::let (::eq_apply (::eq_pair (::eq_refl GI) 
				(::eq_refl x) (::and_l p10) (::and_l p9)) 
				(::and_r p10) (::and_r p9))
			\lemma1. -- ::eq y x
			::apply_eq
				(::eq_refl I)
				(::eq_refl x)
				lemma1
				(::and_l p5 (::iff_lr (::and_l (::and_l 
				(::and_r p5)) x) p6)))
		{ p8 : ::Apply I x y }
			::let (::eq_apply (::eq_refl x)
			(::and_l p5 (::exists_intro (\y. ::Apply I x y) y p8)) p8)
			\lemma1. -- ::eq x y
			::unpack_exists (::and_r (::and_r p4 p6))
			\P.\p9.
			::exists_intro (\P. ::and (::pair GI x P) (::Apply op P y)) P
			(::and_intro (::and_l p9)
			(::apply_eq
				(::eq_refl op)
				(::eq_refl P)
				lemma1
				(::and_r p9)))))))
	\lemma1. -- I#G2

	::let (::and_intro lemma1
	\/x. { p6 : x#G2 }
		::let (::and_l (::iff_lr (p2 x) p6))
		\l_lemma0. -- ::bijection_map A x

		::let (::unpack_exists (::bijection_map_compose l_lemma0 (::and_r p5))
		\h.\p7.

		::let(::bijection_map_compose_id (::and_r p5) l_lemma0 (::and_l p5) 
		(::and_l p7) (::and_l (::and_r (::and_r p7))))
		\l_lemma1. -- ::eq x h

		::iff_rl (p3 p6 lemma1 p6) 
		(\/a.\/b. ::iff_trans (::and_l p7 a b) 
			(::iff_intro ({ p8 : ::Apply h a b }
			::apply_eq (::eq_symm l_lemma1) (::eq_refl a) (::eq_refl b) p8)
			{ p8 : ::Apply x a b}
				::apply_eq l_lemma1 (::eq_refl a) (::eq_refl b) p8)))
		\l_lemma1. -- ::gmul c x I x

		::let(::unpack_exists (::bijection_map_compose (::and_r p5) l_lemma0)
		\h.\p7.

		::let (::bijection_map_id_compose (::and_r p5) l_lemma0 (::and_l p5) 
		(::and_l p7) (::and_l (::and_r (::and_r p7))))
		\l_lemma2. -- ::eq x h

		::iff_rl (p3 lemma1 p6 p6)
		(\/a.\/b. ::iff_trans (::and_l p7 a b) (::iff_intro ({ p8 : ::Apply h a b }
			::apply_eq (::eq_symm l_lemma2) (::eq_refl a) (::eq_refl b) p8)
			{ p8 : ::Apply x a b }
			::apply_eq l_lemma2 (::eq_refl a) (::eq_refl b) p8)))
		\l_lemma2. -- ::gmul c I x x
		::and_intro l_lemma1  l_lemma2)
	\lemma2. -- ::group_identity G2 c I
		

	--lemma2
	::let (\/x. { p6 : x#G2 }
		::let (::iff_lr (p2 x) p6)
		\l_lemma0.
		::unpack_exists (::and_r l_lemma0)
		\a.\p7.
		::unpack_exists (::and_l (::and_r p1) (::and_l p7))
		\ai.\p8.
		::unpack_exists p8
		\GI1.\p9.
		::unpack_exists (::inverse_bijection_map_exists (::and_l l_lemma0))
		\xi.\p10.
		
		::let (::iff_rl (p2 xi)
		(::and_intro (::and_r p10)
		(::exists_intro (\ai. ::and ai#G1 \/y. y#G1 -> \/x. x#G1 -> 
			(::iff (::gmul op ai y x) (::Apply xi y x)))
		(::and_intro (::and_r (::and_l (::and_r p9)))
		\/Y. { p11 : Y#G1 } \/X. { p12 : X#G1 }
			::iff_trans
			(::iff_comm (::gmul_inverse_left p1 p8 p12 p11))
			(::iff_trans (::and_r p7 p12 p11) (::and_l p10 X Y))))))
		\l_lemma1. -- xi#G2
		
		::unpack_exists (::bijection_map_compose (::and_l l_lemma0) 
			(::and_r p10))
		\I1.\p11. -- ::compose x xi I1
		::unpack_exists (::bijection_map_compose (::and_r p10) 
			(::and_l l_lemma0))
		\I2.\p12. -- ::compose xi x I2
		
		::let (::bijection_map_id_eq (::and_r p5) (::and_r p11)
		(::and_l p5) (::compose_inverse (::inverse_inverse (::and_l p10)) 
			(::and_l p11))) 
		\l_lemma2. -- ::eq I I1

		::let (::bijection_map_id_eq (::and_r p5) (::and_r p12)
		(::and_l p5) (::compose_inverse (::and_l p10) (::and_l p12)))
		\l_lemma3. -- ::eq I I2

		::let (::gmul_eq
		(::eq_refl x)
		(::eq_refl xi)
		(::eq_symm l_lemma2)
		(::iff_rl (p3 p6 l_lemma1 (::iff_lr (::eq_ext l_lemma2 G2) lemma1)) 
			(::and_l p11)))
		\l_lemma4. -- ::gmul c x xi I

		::let (::gmul_eq
		(::eq_refl xi)
		(::eq_refl x)
		(::eq_symm l_lemma3)
		(::iff_rl (p3 l_lemma1 p6 (::iff_lr (::eq_ext l_lemma3 G2) lemma1)) 
			(::and_l p12))) 
		\l_lemma5. -- ::gmul c xi x I

		::exists_intro (::group_inverse G2 c x) xi
		(::exists_intro (\I. ::and (::group_identity G2 c I)
			(::and (::and x#G2 xi#G2)
			(::and (::gmul c x xi I) 
				(::gmul c xi x I)))) I
		(::and_intro lemma2
		(::and_intro
		(::and_intro p6 (l_lemma1))
		(::and_intro l_lemma4 l_lemma5)))))
	\lemma3. -- \/x. x#G2 -> ::exists (::group_inverse G2 c x)


	::let (\/x. { p6 : x#G2 } \/y. { p7 : y#G2 }
		::let (::iff_lr (p2 x) p6)
		\l_lemma1.
		::let (::iff_lr (p2 y) p7)
		\l_lemma2.

		::unpack_exists (::and_r l_lemma1)
		\a.\p8.
		::unpack_exists (::and_r l_lemma2)
		\b.\p9.

		::unpack_exists (::and_l (::and_r (::and_r p1)) (::and_l p8) (::and_l p9))
		\ab.\p10.
		::unpack_exists (::bijection_map_compose (::and_l l_lemma1) (::and_l l_lemma2))
		\xy.\p11.

		::let (::iff_rl (p2 xy)
		(::and_intro (::and_r p11)
		(::exists_intro (\ab. ::and ab#G1 \/X.X#G1->\/Y.Y#G1->
			(::iff (::gmul op ab X Y) (::Apply xy X Y))) ab
		(::and_intro (::and_l p10) \/X. { p12 : X#G1 } \/Y. { p13 : Y#G1 }
			::iff_intro
			({ p14 : ::gmul op ab X Y }
				::unpack_exists (::and_l (::and_r (::and_r p1)) 
					(::and_l p9) p12)
				\bX.\p15.
				::iff_lr (::and_l p11 X Y)
				(::exists_intro (\q. ::and (::Apply y X q ) (::Apply x q Y)) bX
				(::and_intro
				(::iff_lr (::and_r p9 p12 (::and_l p15))
					(::and_r p15)) --Apply y X bX
				(::iff_lr (::and_r p8 (::and_l p15) p13)
				(::iff_lr (::group_assoc p1 (::and_l p8) (::and_l p9) p12 
				(::and_l p10) (::and_l p15) 
				(::and_r p10) (::and_r p15) Y) p14))))) -- ::Apply a bX Y
			{ p14 : ::Apply xy X Y }
				::unpack_exists (::and_l (::and_r (::and_r p1)) 
					(::and_l p9) p12)
				\bX.\p15.
				::unpack_exists (::iff_rl (::and_l p11 X Y) p14)
				\bX1.\p16.
				::unpack_exists (::and_l (::and_r (::and_r p1)) 
					(::and_l p8) (::and_l p15))
				\abX.\p17.
				
				::let (::eq_apply
				(::eq_refl bX)
				(::apply_eq
				(::eq_refl x)
				(::eq_apply
				(::eq_refl X)
				(::and_l p16)
				(::iff_lr (::and_r p9 p12 (::and_l p15)) 
					(::and_r p15))) --::eq bX1 bX
				(::eq_refl Y)
				(::and_r p16))
				(::iff_lr (::and_r p8 (::and_l p15) (::and_l p17)) 
					(::and_r p17))) 
				\l_lemma1. --::eq Y abX

				::gmul_eq
				(::eq_refl ab)
				(::eq_refl X)
				(::eq_symm l_lemma1)
				(::iff_rl (::group_assoc p1 (::and_l p8) (::and_l p9) p12
				(::and_l p10) (::and_l p15) 
				(::and_r p10) (::and_r p15) abX)
				(::and_r p17))))))
		\l_lemma1. -- xy#G2
		::exists_intro (\xy. ::and xy#G2 (::gmul c x y xy)) xy
		(::and_intro l_lemma1
		(::iff_rl (p3 p6 p7 l_lemma1) (::and_l p11))))
	\lemma4.  -- \/x. x#G2 -> \/y. y#G2 -> (::exists \z. ::and z#G2 (::gmul x y z))

	::let (\/x. { p6 : x#G2 } \/y. { p7 : y#G2 } \/z. { p8 : z#G2 }
		::unpack_exists (lemma4 p6 p7)
		\xy.\p9.
		::unpack_exists (lemma4 p7 p8)
		\yz.\p10.
		::unpack_exists (lemma4 (::and_l p9) p8)
		\xyz.\p11.

		::exists_intro (\xyz. ::and 
			(::exists \xy. ::and (::gmul c x y xy) (::gmul c xy z xyz))
			(::exists \yz. ::and (::gmul c y z yz) (::gmul c x yz xyz))) xyz
		(::and_intro
		(::exists_intro (\xy. ::and (::gmul c x y xy) (::gmul c xy z xyz)) xy
		(::and_intro (::and_r p9) (::and_r p11)))
		(::exists_intro (\yz. ::and (::gmul c y z yz) (::gmul c x yz xyz)) yz
		(::and_intro (::and_r p10)
		(::iff_rl (p3 p6 (::and_l p10) (::and_l p11))
		(::iff_rl (::compose_assoc 
		(::iff_lr (p3 p6 p7 (::and_l p9)) (::and_r p9))
		(::iff_lr (p3 p7 p8 (::and_l p10)) (::and_r p10)) xyz)
		(::iff_lr (p3 (::and_l p9) p8 (::and_l p11)) (::and_r p11))))))))
	\lemma5.

	(::and_intro (::exists_intro (::group_identity G2 c) I lemma2)
	(::and_intro lemma3
	(::and_intro lemma4 lemma5))) ;


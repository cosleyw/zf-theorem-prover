	\lemma1. -- ::id F

	::let (\/x. ::iff_intro
	({ p3 : x#A }
		::unpack_exists (::pair_exists x x)
		\P.\p4.

		::let (::exists_intro (\Q. ::and (::pair x x Q) Q#F) P
		(::and_intro p4 (::iff_rl (p2 P) (::and_intro (p1 p3 p3 p4)
		(::exists_intro (\x. ::and x#A (::pair x x P)) x (::and_intro p3 p4))))))
		\lemma1.

		::exists_intro (\y. ::Apply F x y) x 
		(::and_intro lemma1
		\/y.\/Q.{ p5 : ::and (::pair x y Q) Q#F }
			::unpack_exists (::and_r (::iff_lr (p2 Q) (::and_r p5)))
			\x1.\p6.
